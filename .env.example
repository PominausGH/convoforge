# --- Backend (FastAPI) ---
DATABASE_URL=postgresql+asyncpg://andrew:convoforge@postgres-main:5432/convoforge
APP_URL=http://localhost:3015

# Anthropic (Carnegie + sincerity scoring)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (avatar TTS via /v1/audio/speech). Optional — without it, the browser
# falls back to native speechSynthesis (lower quality, especially on Linux).
OPENAI_API_KEY=sk-...
OPENAI_TTS_VOICE=nova
OPENAI_TTS_MODEL=tts-1

# Deepgram (streaming STT). Audio is proxied through FastAPI's WebSocket relay,
# so the key never reaches the browser.
DEEPGRAM_API_KEY=...

# Stripe (Pro tier, regional pricing)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Cloudflare R2 (opt-in recordings)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=convoforge-recordings

# --- Frontend (Next.js) ---
BACKEND_URL=http://cf_api:8000

# Public WebSocket origin for the Deepgram audio relay. Browser-resolvable.
# Local dev: ws://localhost:8000   Prod: wss://api.convoforge.example.com
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000

# Public site URL — used for canonical, sitemap, OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=https://convoforge.app

# Umami analytics. Leave blank to disable. The script URL's origin is
# automatically added to the CSP at build time.
# NEXT_PUBLIC_UMAMI_SRC=https://umami.example.com/script.js
# NEXT_PUBLIC_UMAMI_ID=00000000-0000-0000-0000-000000000000

# --- Sentry (hosted, sentry.io — free tier, 5k errors/month) ---
# Create a project at sentry.io and paste its DSN below.
# The origin of NEXT_PUBLIC_SENTRY_DSN is auto-added to CSP at build time.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXXX.ingest.us.sentry.io/XXXXXXX
# SENTRY_DSN_API=https://yyy@oXXXXXX.ingest.us.sentry.io/XXXXXXX
